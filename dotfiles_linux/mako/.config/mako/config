# Enable icons (should be default, but let's be explicit)
icons=1
max-icon-size=64
icon-path=/usr/share/icons/Papirus
on-button-right=exec makoctl menu -n "$id" -- fuzzel --dmenu --anchor=top-right
# Left-click invokes the default action (e.g. Claude Code "Focus window").
on-button-left=invoke-default-action
# Middle-click dismisses without invoking any action (no focus change).
on-button-middle=dismiss

