# Enable icons (should be default, but let's be explicit)
icons=1
max-icon-size=64
icon-path=/usr/share/icons/Papirus
on-button-right=exec makoctl menu -n "$id" -- fuzzel --dmenu --anchor=top-right
# Left-click invokes the default action (e.g. Claude Code "Focus window").
on-button-left=invoke-default-action
# Middle-click dismisses without invoking any action (no focus change).
on-button-middle=dismiss

# Claude Code hooks tag notifications with --category=ws-<workspace>; stack
# notifications from the same workspace together.
[app-name="Claude Code"]
group-by=category

# Do-not-disturb, toggled from the waybar bell module (waybar-mako-dnd) via
# `makoctl mode -t do-not-disturb`. Notifications still queue while active
# and appear once the mode is turned off (if they haven't timed out).
[mode=do-not-disturb]
invisible=1

