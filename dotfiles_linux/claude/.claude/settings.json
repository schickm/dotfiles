{
  "env": {
    "CLAUDE_AFK_TIMEOUT_MS": "86400000"
  },
  "permissions": {
    "allow": [
      "WebFetch",
      "WebSearch",
      "mcp__figma__get_design_context",
      "mcp__figma__get_screenshot",
      "mcp__slack__conversations_replies",
      "mcp__slack__conversations_search_messages",
      "mcp__slack__conversations_history",
      "Bash(npm test:*)",
      "Bash(git commit:*)",
      "Bash(gh pr create:*)",
      "Bash(ls:*)",
      "mcp__chrome-devtools__*",
      "Skill(notify)",
      "Skill(qa-notes)",
      "Bash(~/.claude/skills/notify/push.sh:*)"
    ],
    "additionalDirectories": [
      "~/workvc/rwgps-ui/",
      "/tmp"
    ]
  },
  "model": "claude-fable-5[1m]",
  "hooks": {
    "PreCompact": [],
    "SessionStart": [],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/bin/claude-permission-hook.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/bin/claude-disarm-watchdog.sh"
          },
          {
            "type": "command",
            "command": "~/bin/workspace-activity hook prompt-submit"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/bin/workspace-activity hook pre-tool"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/bin/workspace-activity hook post-tool"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/bin/workspace-activity hook subagent-stop"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/bin/workspace-activity hook session-end"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/bin/claude-inactivity-watchdog.sh"
          },
          {
            "type": "command",
            "command": "~/bin/claude-stop-hook.sh"
          },
          {
            "type": "command",
            "command": "~/bin/workspace-activity hook stop"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "workspace-manager-status@workspace-manager": false
  },
  "sandbox": {
    "enabled": false,
    "autoAllowBashIfSandboxed": true
  },
  "alwaysThinkingEnabled": true,
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "theme": "light",
  "preferredNotifChannel": "notifications_disabled",
  "inputNeededNotifEnabled": false,
  "agentPushNotifEnabled": false
}
