#!/bin/bash
set -e

# Usage: niri-workspace-profile <workspace-name> <profile> [args...]
#
# Runs a workspace profile script from ~/.config/niri-workspaces/<profile>.sh
# Any additional arguments are passed to the script.
#
# Example script (~/.config/niri-workspaces/dev.sh):
#
#   #!/bin/bash
#   cwd="$1"
#   cd "$cwd"
#   nohup alacritty-run k &
#   nohup google-chrome-stable --new-window https://localhost:3000 &

workspace_name="$1"
profile="$2"
shift 2 || true

if [[ -z "$workspace_name" || -z "$profile" ]]; then
    echo "Usage: $(basename "$0") <workspace-name> <profile> [args...]"
    exit 1
fi

script_file="$HOME/.config/niri-workspaces/${profile}.sh"

if [[ ! -f "$script_file" ]]; then
    echo "Profile not found: $script_file"
    exit 1
fi

# Create the workspace
niri-create-workspace "$workspace_name"

# Run the script with remaining args, capture stderr, notify on failure
error_output=$(mktemp)
if ! bash "$script_file" "$@" 2>"$error_output" >/dev/null; then
    error_msg=$(cat "$error_output")
    notify-send -u critical "Workspace profile failed: $profile" "$error_msg"
    rm -f "$error_output"
    exit 1
fi
rm -f "$error_output"
