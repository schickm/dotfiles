[Desktop Entry]
Version=1.0
Type=Application
Name=Google Chrome (Personal)
GenericName=Web Browser
Comment=Personal profile
Keywords=personal;browser;
Icon=google-chrome
Exec=env -u XDG_ACTIVATION_TOKEN /usr/bin/google-chrome-stable "--profile-directory=Default" %U
Terminal=false
StartupNotify=false
StartupWMClass=Google-chrome
Categories=Network;WebBrowser;
