#!/bin/bash
set -e

source "$(dirname "$(readlink -f "$0")")/workspace-lib.sh"

# Prompt for GitHub issue URL
issue_url=$(echo "" | fuzzel --dmenu --prompt "GitHub issue URL: ")
[[ -z "$issue_url" ]] && exit 0

# Extract issue number from URL (last number in the path)
issue_num=$(echo "$issue_url" | grep -oE '[0-9]+$')
[[ -z "$issue_num" ]] && notify-send -u critical "Start Ticket Failed" "Could not extract issue number from URL" && exit 1

# Pick the workspace container: infer it from the URL's org/repo slug by
# matching each container's origin remote; fall back to a picker.
container=""
if [[ "$issue_url" =~ github\.com[:/]([^/]+/[^/?#]+) ]]; then
	container=$(container_for_github_slug "${BASH_REMATCH[1]}") || container=""
fi
if [[ -z "$container" ]]; then
	repo=$(workspace_containers | xargs -rn1 basename | fuzzel --dmenu --prompt "Repository: ")
	[[ -z "$repo" ]] && exit 0
	container="$WORKVC_BASE/$repo"
fi

load_workspacerc "$container"
[[ -z "$MAIN_WORKTREE" ]] && notify-send -u critical "Start Ticket Failed" "No main worktree found in $container" && exit 1

# Use Claude to generate a short descriptive name (for workspace)
claude_settings='{"permissions":{"allow":["Bash(gh:*)"]}}'
claude_prompt="Given this GitHub issue URL: $issue_url

Use the GitHub CLI (gh) to fetch the issue details - do not try to load from the public URL.

Generate a short descriptive name. Requirements:
- Maximum 25 characters
- Use kebab-case (lowercase with hyphens)
- Be descriptive but concise
- Do NOT include the issue number
- Output ONLY the name, nothing else"

workspace_name=$(with_notification "Starting ticket..." "Generating workspace name..." \
	claude -p --model haiku --setting-sources "" --settings "$claude_settings" "$claude_prompt")

# Validate workspace name isn't empty
[[ -z "${workspace_name//[[:space:]]/}" ]] && notify-send -u critical "Start Ticket Failed" "Could not generate workspace name" && exit 1

# Create branch name by appending issue number
branch="${workspace_name}-${issue_num}"

# CD into the main worktree and create the new worktree with wt-add
cd "$container/$MAIN_WORKTREE"
with_notification "Setting up worktree..." "$branch" fish -c "wt-add ../$branch" ||
	{
		notify-send -u critical "Start Ticket Failed" "Failed to create worktree: $branch"
		exit 1
	}

# Write CLAUDE.local.md with ticket context. Remove any symlink first
# (.wt-addrc may seed one pointing at the container's shared file — writing
# through it would clobber that shared file for every worktree).
cat >"$container/$branch/CLAUDE.local.md" <<EOF
This worktree's purpose is to implement the following GitHub ticket:

$issue_url
EOF

# Prompt to launch workspace
action=$(notify-send --wait --action="yes=Yes" --action="no=No" "Workspace Ready" "Launch workspace $branch?")
[[ "$action" != "yes" ]] && exit 0

# Launch dev environment via resume-workspace
resume-workspace "$(basename "$container")/$branch" "$issue_url"
