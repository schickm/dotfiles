#!/bin/bash
# Usage: kitty-run <command>
# Launches kitty with fish and sends the command to run interactively

socket="/tmp/kitty-$$.sock"
cmd="$*"

kitty --listen-on "unix:$socket" fish &

# Poll kitty and wait until it's ready
for _ in $(seq 1 50); do
    kitty @ --to "unix:$socket" ls &>/dev/null && break
    sleep 0.1
done

kitty @ --to "unix:$socket" send-text "$cmd\n"
