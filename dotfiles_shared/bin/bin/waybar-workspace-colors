#!/bin/bash
# Generate per-repo background colors for waybar's niri/workspaces buttons.
#
# Workspace names are worktree dir names (resume-workspace passes them to
# niri-create-workspace), and waybar names each button niri-workspace-<name>,
# so scanning the workspace containers on disk is enough to map every
# possible workspace to its repo's color — no runtime state needed. Each repo
# gets its color from .workspacerc's WORKSPACE_COLOR (or a hashed fallback,
# see workspace_color in workspace-lib.sh).
#
# Writes ~/.config/waybar/workspace-colors.css (@imported by style.css;
# gitignored since ~/.config/waybar is stowed into the dotfiles repo) only
# when the output actually changed; waybar re-applies it in place via its
# reload_style_on_change option. Runs from waybar's ExecStartPre drop-in and
# from resume-workspace.
set -e

source "$(dirname "$(readlink -f "$0")")/workspace-lib.sh"

css_file="$HOME/.config/waybar/workspace-colors.css"

generate() {
    echo "/* Generated by waybar-workspace-colors — do not edit. */"
    local container color dir name
    for container in $(workspace_containers); do
        color=$(workspace_color "$container")
        for dir in "$container"/*/; do
            dir="${dir%/}"
            [[ -e "$dir/.git" ]] || continue
            name=$(basename "$dir")
            # The name lands in a CSS id selector; skip anything that would
            # need escaping there (worktree names are kebab-case in practice).
            [[ "$name" =~ ^[A-Za-z0-9_-]+$ ]] || continue
            # Main-worktree names collide across repos AND with hand-named
            # niri workspaces (e.g. the general-purpose "main"), so leave
            # them unstyled rather than color them by whichever repo wins.
            case "$name" in master|main|trunk) continue ;; esac
            cat <<EOF

/* $(basename "$container") */
#workspaces button#niri-workspace-$name {
    background-color: alpha($color, 0.45);
    color: #ffffff;
}
#workspaces button#niri-workspace-$name.focused {
    background-color: $color;
    box-shadow: inset 0 -3px #ffffff;
}
EOF
        done
    done
}

new_css=$(generate)

if [[ ! -f "$css_file" ]] || [[ "$new_css" != "$(cat "$css_file")" ]]; then
    tmp=$(mktemp "$css_file.XXXXXX")
    printf '%s\n' "$new_css" > "$tmp"
    mv "$tmp" "$css_file"
    # No reload signal needed: waybar runs with reload_style_on_change and
    # re-applies the CSS in place (a SIGUSR2 reload would tear down the bar
    # surface and momentarily shift every window).
fi
