#!/usr/bin/env fish

# kitty `open_url_with` handler.
#
# Goal: open a clicked URL in whatever Chrome window lives on the same niri
# workspace as the kitty window the click happened in. No routing to
# claude-chrome anymore — that's reserved for headless testing.
#
# Mechanism: Chrome has no CLI to target a specific window, but a URL handed
# to a running instance opens as a new tab in the profile's last-activated
# window. So: focus the workspace's Chrome window first (which also makes its
# profile the last-used one), give Chrome a beat to register the activation,
# then hand it the URL with no --profile-directory so it follows that window.
#
# The kitty window that was clicked is focused, so the focused niri workspace
# IS the workspace the click came from — no kitty remote-control cwd dance
# needed. Floating Chrome windows are skipped (the picture-in-picture rule in
# niri's config makes those floating; they aren't tabbed browser windows).
#
# XDG_ACTIVATION_TOKEN is stripped everywhere so Chrome can't redeem a stale
# token on some other window and yank focus across workspaces.

set -l url $argv[1]
test -n "$url"; or exit 0

set -l ws_id (niri msg --json workspaces | jq '[.[] | select(.is_focused==true) | .id] | first')

set -l win_id (niri msg --json windows | jq --argjson ws "$ws_id" \
    '[.[] | select(.app_id=="google-chrome" and .workspace_id==$ws and .is_floating==false) | .id] | first // empty')

if test -n "$win_id"
    # Chrome window on this workspace → focus it, then open the URL as a tab
    # in it (last-activated window of the last-used profile).
    niri msg action focus-window --id $win_id
    sleep 0.3
    env -u XDG_ACTIVATION_TOKEN google-chrome-stable $url
else
    # No Chrome here → open a fresh window. Tokenless windows map onto the
    # currently focused workspace, i.e. right where the click happened.
    # No --profile-directory: last-used profile, same as Chrome's default.
    env -u XDG_ACTIVATION_TOKEN google-chrome-stable --new-window $url
end
