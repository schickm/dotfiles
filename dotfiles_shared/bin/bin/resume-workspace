#!/bin/bash
set -e

source "$(dirname "$(readlink -f "$0")")/workspace-lib.sh"

# Internal mode: the whole app-launch phase, re-executed by the main flow
# under niri-spawn-on-workspace so that Chrome, the terminals, and anything a
# .workspacerc workspace_launch spawns share one fresh session — the watcher
# then routes their windows to the workspace even if focus has moved on.
# Args: <repo>/<worktree> [chrome-urls...]
if [[ "${1:-}" == "--spawn-apps" ]]; then
    shift
    selected="$1"
    shift
    repo="${selected%%/*}"
    worktree="${selected#*/}"
    container="$WORKVC_BASE/$repo"
    worktree_dir="$container/$worktree"

    load_workspacerc "$container"
    cd "$worktree_dir"

    # Launch this workspace's Chrome window from the regular work profile
    # (claude-chrome is now reserved for headless testing). The window comes
    # from the already-running Chrome instance, so it escapes
    # niri-spawn-on-workspace's session matching — snapshot window ids first
    # and move the new google-chrome window here ourselves. The token is
    # stripped so Chrome can't redeem fuzzel's activation token on an
    # existing window and yank focus to another workspace.
    chrome_before=$(niri msg --json windows |
        jq '[.[] | select(.app_id=="google-chrome") | .id]')
    env -u XDG_ACTIVATION_TOKEN google-chrome-stable \
        "--profile-directory=Profile 1" --new-window "$@" &>/dev/null &
    (
        for _ in $(seq 1 50); do
            new_id=$(niri msg --json windows | jq --argjson before "$chrome_before" \
                '([.[] | select(.app_id=="google-chrome") | .id] - $before) | first // empty')
            if [[ -n "$new_id" ]]; then
                niri msg action move-window-to-workspace \
                    --window-id "$new_id" --focus false "$worktree"
                break
            fi
            sleep 0.2
        done
    ) &>/dev/null &

    # Launch terminal windows (per-repo recipe from .workspacerc, or the default)
    workspace_launch "$worktree_dir"
    exit 0
fi

# Check if called with arguments (from start-new-ticket) or interactively
if [[ -n "$1" ]]; then
    # Called with arguments: <repo>/<worktree>, issue_url
    selected="$1"
    issue_url="$2"
else
    # Interactive mode: prompt user to select a workspace across all
    # containers, sorted by how recently anything inside each worktree
    # changed (most recent first). Heavy/churny dirs are pruned so the mtime
    # scan is fast AND reflects actual code work: node_modules/dist/build are
    # bulky, .git is constant bookkeeping, and .claude-chrome (the
    # per-worktree browser profile) rewrites cache files on every page load,
    # which would otherwise float whichever workspace you last browsed in to
    # the top.
    worktrees=$(
        for container in $(workspace_containers); do
            repo=$(basename "$container")
            for dir in "$container"/*/; do
                [[ -e "$dir/.git" ]] || continue
                ts=$(find "$dir" \( -name node_modules -o -name .git \
                        -o -name .claude-chrome -o -name dist -o -name build \
                        -o -name .next -o -name .vite -o -name coverage \
                        -o -name .cache \) -prune -o \
                    -type f -printf '%T@\n' 2>/dev/null | sort -nr | head -1)
                printf '%s\t%s/%s\n' "${ts:-0}" "$repo" "$(basename "$dir")"
            done
        done | sort -rn | cut -f2-
    )
    selected=$(echo "$worktrees" | fuzzel --dmenu --prompt "Resume workspace: ")
    [[ -z "$selected" ]] && exit 0
fi

repo="${selected%%/*}"
worktree="${selected#*/}"
container="$WORKVC_BASE/$repo"
worktree_dir="$container/$worktree"

[[ -d "$worktree_dir" ]] || { notify-send -u critical "Resume Workspace Failed" "No such worktree: $selected"; exit 1; }

load_workspacerc "$container"
cd "$worktree_dir"

# Look up the PR for the current branch
pr_url=$(with_notification "Resuming workspace..." "Looking up pull request..." \
    gh pr view --json url -q .url 2>/dev/null || true)

# Create niri workspace with the descriptive name (no issue number)
niri-create-workspace "$worktree"

# Refresh waybar's per-repo workspace colors (a new worktree has no rule yet)
waybar-workspace-colors || true

# Chrome opens the repo's own URLs (from the .workspacerc workspace_urls
# hook, e.g. a dev-server hotlink) plus issue/PR if present.
chrome_urls=()
while IFS= read -r url; do
    [[ -n "$url" ]] && chrome_urls+=("$url")
done < <(workspace_urls "$worktree_dir")
[[ -n "$issue_url" ]] && chrome_urls+=("$issue_url")
[[ -n "$pr_url" ]] && chrome_urls+=("$pr_url")

# Launch everything (Chrome + terminals) via --spawn-apps under
# niri-spawn-on-workspace: apps map their windows asynchronously, so late
# arrivals get moved onto this workspace instead of wherever focus is now.
niri-spawn-on-workspace "$worktree" "$0" --spawn-apps "$selected" "${chrome_urls[@]}"
